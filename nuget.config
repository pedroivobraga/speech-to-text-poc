<?xml version="1.0" encoding="utf-8"?>
<!--
  Restringe a restauração deste projeto ao nuget.org.
  Evita que o feed privado (AmeLingerie) intercepte pacotes públicos como
  Whisper.net.Runtime e falhe com 402 (Payment Required).
  Por ser um nuget.config local, não afeta os demais projetos da máquina.
-->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
